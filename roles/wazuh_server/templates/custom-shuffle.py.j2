#!/usr/bin/env python3
"""
Wazuh custom integration: forward alerts to Shuffle SOAR webhook.
Placed at /var/ossec/integrations/custom-shuffle on the wazuh.manager container.
"""
import json
import sys
import urllib.request
import urllib.error

SHUFFLE_WEBHOOK_URL = (
    "http://{{ wazuh_server_ip }}:5001"
    "/api/v1/hooks/{{ shuffle_webhook_trigger_id }}"
)
SHUFFLE_API_KEY = "{{ shuffle_default_apikey }}"


def main():
    alert_file_path = sys.argv[1]
    with open(alert_file_path) as f:
        alert = json.load(f)

    payload = json.dumps(alert).encode("utf-8")
    req = urllib.request.Request(
        SHUFFLE_WEBHOOK_URL,
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {SHUFFLE_API_KEY}",
        },
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=10)
    except urllib.error.URLError as e:
        sys.stderr.write(f"Shuffle integration error: {e}\n")
        sys.exit(1)


if __name__ == "__main__":
    main()
