{
  "id": "{{ shuffle_workflow_id }}",
  "name": "Wazuh Alert to DFIR-IRIS Case",
  "description": "Automatically creates a DFIR-IRIS case when Wazuh fires an alert (level >= {{ wazuh_alert_min_level }})",
  "tags": ["wazuh", "iris", "soc"],
  "status": "running",
  "workflow_variables": [],
  "actions": [
    {
      "id": "iris-create-case",
      "app_name": "HTTP",
      "app_version": "1.3.0",
      "app_id": "http",
      "name": "Create IRIS Case",
      "label": "Create IRIS Case",
      "large_image": "",
      "environment": "Shuffle",
      "is_valid": true,
      "skip_multicheck": false,
      "parameters": [
        {
          "name": "url",
          "value": "https://{{ wazuh_server_ip }}:4444/api/v1/cases/add",
          "id": "url-param",
          "description": "DFIR-IRIS API endpoint"
        },
        {
          "name": "headers",
          "value": "Authorization: Bearer {{ iris_adm_api_key }}\r\nContent-Type: application/json",
          "id": "headers-param"
        },
        {
          "name": "body",
          "value": "{\"case_name\": \"Wazuh: $exec.rule.description\", \"case_description\": \"**Rule ID**: $exec.rule.id\\n**Agent**: $exec.agent.name\\n**Level**: $exec.rule.level\\n**Source IP**: $exec.data.srcip\", \"case_soc_id\": \"W-$exec.id\", \"case_customer\": 1}",
          "id": "body-param"
        },
        {
          "name": "verify",
          "value": "false",
          "id": "verify-param"
        }
      ],
      "position": {"x": 500, "y": 250}
    }
  ],
  "triggers": [
    {
      "app_name": "Shuffle Triggers",
      "name": "Wazuh Webhook",
      "description": "Receives JSON alerts from Wazuh custom integration",
      "id": "{{ shuffle_webhook_trigger_id }}",
      "type": "WEBHOOK",
      "status": "running",
      "app_version": "1.0.0",
      "parameters": [
        {
          "name": "info",
          "value": "Receives Wazuh alerts via HTTP POST",
          "id": "info-param"
        }
      ],
      "position": {"x": 50, "y": 250}
    }
  ],
  "branches": [
    {
      "id": "branch-wazuh-iris",
      "source_id": "{{ shuffle_webhook_trigger_id }}",
      "destination_id": "iris-create-case",
      "label": ""
    }
  ]
}
