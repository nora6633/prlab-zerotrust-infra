worker_processes  1;

events {
    worker_connections  1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    keepalive_timeout  65;

    # Combined log format — Wazuh prlab-nginx-access decoder parses this.
    log_format  combined_extended  '$remote_addr - $remote_user [$time_local] '
                                   '"$request" $status $body_bytes_sent '
                                   '"$http_referer" "$http_user_agent"';

    access_log  logs/access.log  combined_extended;

    # Rate-limit zone — always defined, only enforced when Active Response
    # writes the limit_req directive into limit-active.conf (Level 8 alert).
    limit_req_zone  $binary_remote_addr  zone=arratelimit:10m  rate=10r/s;

    upstream juiceshop {
        server 127.0.0.1:{{ juice_shop_upstream_port }};
    }

    server {
        listen       {{ nginx_listen_port }};
        server_name  _;

        location / {
            # Toggled by Active Response (file is empty by default).
            include  conf/limit-active.conf;

            proxy_pass         http://juiceshop;
            proxy_http_version 1.1;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
            proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
        }
    }
}
