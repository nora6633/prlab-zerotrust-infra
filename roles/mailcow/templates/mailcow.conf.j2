# Mailcow configuration — generated by Ansible
# See https://docs.mailcow.email/getstarted/install/ for reference

MAILCOW_HOSTNAME=mail.{{ domain }}
MAILCOW_PASS_SCHEME=BLF-CRYPT

# Database
DBNAME={{ mailcow_db_name }}
DBUSER={{ mailcow_db_user }}
DBPASS={{ mailcow_db_password }}
DBROOT={{ mailcow_db_root_password }}

# Redis
REDISPASS={{ mailcow_redis_password }}

# Web ports
HTTP_PORT=80
HTTPS_PORT=443
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0

# Mail ports
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190
DOVEADM_PORT=19991
SQL_PORT=13306
SOLR_PORT=18983
REDIS_PORT=7654

# Misc
TZ=UTC
COMPOSE_PROJECT_NAME=mailcow-dockerized
DOCKER_COMPOSE_VERSION=native
WATCHDOG_NOTIFY_BAN=y
WATCHDOG_NOTIFY_EMAIL=
WATCHDOG_EXTERNAL_CHECKS=n
WATCHDOG_MYSQL_REPLICATION_RUNNING=n
ACME_CONTACT=
ACME_STAGING=n
MAILDIR_GC_TIME=1440
ADDITIONAL_SAN=
ADDITIONAL_SERVER_NAMES=
SKIP_LETS_ENCRYPT=y
ENABLE_SSL_SNI=n
SKIP_IP_CHECK=n
SKIP_HTTP_VERIFICATION=n
SKIP_CLAMD=n
SKIP_SOGO=n
SKIP_SOLR=n
ALLOW_ADMIN_EMAIL_LOGIN=n
USE_WATCHDOG=y
LOG_LINES=9999
IPV4_NETWORK=172.22.1
IPV6_NETWORK=fd4d:6169:6c63:6f77::/64
SNAT_TO_SOURCE=
SNAT6_TO_SOURCE=
API_KEY=
API_KEY_READ_ONLY=
API_ALLOW_FROM=127.0.0.1,::1
MAILCOW_UPDATES=y
MAILCOW_UPDATE_TIER=stable
