services:
  freeipa:
    image: freeipa/freeipa-server:almalinux-9
    container_name: freeipa
    hostname: ipa.{{ domain }}
    restart: unless-stopped
    ports:
      - "8080:80"
      - "8443:443"
      - "389:389"
      - "636:636"
      - "88:88/tcp"
      - "88:88/udp"
      - "464:464/tcp"
      - "464:464/udp"
      - "123:123/udp"
    environment:
      - IPA_SERVER_INSTALL_OPTS=-U -r {{ freeipa_realm }} --setup-dns --no-forwarders --admin-password={{ freeipa_admin_password }} --ds-password={{ freeipa_ds_password }}
    volumes:
      - freeipa-data:/data
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
    sysctls:
      - net.ipv6.conf.all.disable_ipv6=0
    tmpfs:
      - /run
      - /tmp
    cap_add:
      - SYS_TIME
      - NET_ADMIN
      - DAC_OVERRIDE

volumes:
  freeipa-data:
