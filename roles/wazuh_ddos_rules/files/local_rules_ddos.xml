<!-- DDoS HTTP flood detection on nginx reverse proxy.
     Two tiers: Level 8 triggers nginx rate limit; Level 10 triggers Windows Firewall block. -->
<group name="nginx,prlab,web,">

  <rule id="100200" level="0">
    <decoded_as>prlab-nginx-access</decoded_as>
    <description>Nginx: web access</description>
  </rule>

  <rule id="100210" level="8" frequency="50" timeframe="10">
    <if_matched_sid>100200</if_matched_sid>
    <same_source_ip />
    <description>Nginx: HTTP flood (warn) from $(srcip) - rate limit triggered</description>
    <group>http_flood,attack,</group>
    <mitre>
      <id>T1499.002</id>
    </mitre>
  </rule>

  <rule id="100211" level="10" frequency="100" timeframe="10">
    <if_matched_sid>100200</if_matched_sid>
    <same_source_ip />
    <description>Nginx: HTTP flood (block) from $(srcip) - IP blocked</description>
    <group>http_flood,attack,</group>
    <mitre>
      <id>T1499.002</id>
    </mitre>
  </rule>

</group>
